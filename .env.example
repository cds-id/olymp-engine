# App
OLYMP__APP__URL=http://localhost:3000
OLYMP__APP__ENVIRONMENT=dev

# Database
OLYMP__DATABASE__URL=postgres://olymp:olymp@localhost:5432/olymp
OLYMP__DATABASE__MAX_CONNECTIONS=10

# Redis
OLYMP__REDIS__URL=redis://localhost:6379

# Auth
OLYMP__AUTH__JWT_SECRET=change-me
OLYMP__AUTH__COOKIE_SECRET=change-me

# Email
OLYMP__EMAIL__PROVIDER=mailgun
OLYMP__EMAIL__API_KEY=
OLYMP__EMAIL__FROM=noreply@olymp.id
OLYMP__EMAIL__DOMAIN=mg.olymp.id

# Storage (S3-compatible)
OLYMP__STORAGE__ENDPOINT=
OLYMP__STORAGE__BUCKET=olymp-media
OLYMP__STORAGE__ACCESS_KEY=
OLYMP__STORAGE__SECRET_KEY=
OLYMP__STORAGE__REGION=auto
OLYMP__STORAGE__CDN_URL=
