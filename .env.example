# App
BLURP__APP__URL=http://localhost:3000
BLURP__APP__ENVIRONMENT=dev

# Database
BLURP__DATABASE__URL=postgres://blurp:blurp@localhost:5432/blurp
BLURP__DATABASE__MAX_CONNECTIONS=10

# Redis
BLURP__REDIS__URL=redis://localhost:6379

# Auth
BLURP__AUTH__JWT_SECRET=change-me
BLURP__AUTH__COOKIE_SECRET=change-me

# Payment
BLURP__PAYMENT__PROVIDER=xendit
BLURP__PAYMENT__API_KEY=xnd_dev_xxx
BLURP__PAYMENT__SECRET_KEY=xxx
BLURP__PAYMENT__WEBHOOK_SECRET=xxx

# Shipping
BLURP__SHIPPING__PROVIDER=rajaongkir
BLURP__SHIPPING__API_KEY=xxx

# Email
BLURP__EMAIL__PROVIDER=mailgun
BLURP__EMAIL__API_KEY=key-xxx
BLURP__EMAIL__FROM=noreply@sorastore.com
BLURP__EMAIL__DOMAIN=mg.sorastore.com

# Storage (S3/R2)
BLURP__STORAGE__ENDPOINT=https://xxx.r2.cloudflarestorage.com
BLURP__STORAGE__BUCKET=blurp-media
BLURP__STORAGE__ACCESS_KEY=xxx
BLURP__STORAGE__SECRET_KEY=xxx
BLURP__STORAGE__REGION=auto
BLURP__STORAGE__CDN_URL=https://media.sorastore.com

# Server
BLURP__SERVER__BIND_ADDR=0.0.0.0:8080

# Email - Mailgun (primary for transactional)
BLURP__EMAIL__MAILGUN_API_KEY=your-mailgun-api-key
BLURP__EMAIL__MAILGUN_DOMAIN=mail.yourdomain.com
BLURP__EMAIL__FROM_NAME=SoraStore

# Email - SMTP (backup)
BLURP__EMAIL__SMTP_HOST=smtp.provider.com
BLURP__EMAIL__SMTP_PORT=587
BLURP__EMAIL__SMTP_USER=user@domain.com
BLURP__EMAIL__SMTP_PASSWORD=your-smtp-password
BLURP__EMAIL__SMTP_FROM=no-reply@domain.com
